---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Checkout" description="Complete your Kustom Fits order securely with Stripe.">
  <Header slot="header" />

  <section class="px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-2xl">
      <h1 class="font-display text-4xl tracking-wide text-white">Checkout</h1>

      <div id="checkout-empty" class="mt-8 hidden rounded-2xl border border-white/10 bg-brand-card p-8 text-center">
        <p class="text-brand-gray">Your cart is empty.</p>
        <a href="/shop" class="mt-4 inline-block text-brand-cyan hover:text-white">Continue shopping →</a>
      </div>

      <div id="checkout-content" class="mt-8 space-y-6">
        <div class="rounded-2xl border border-white/10 bg-brand-card p-6">
          <h2 class="font-display text-lg tracking-wide text-white">Order summary</h2>
          <ul id="checkout-items" class="mt-4 space-y-3 text-sm"></ul>
          <dl class="mt-6 space-y-2 border-t border-white/10 pt-4 text-sm">
            <div class="flex justify-between">
              <dt class="text-brand-gray">Subtotal</dt>
              <dd id="checkout-subtotal">£0.00</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-brand-gray">UK shipping</dt>
              <dd id="checkout-shipping">£3.95</dd>
            </div>
            <div class="flex justify-between text-base font-semibold">
              <dt>Total</dt>
              <dd id="checkout-total">£0.00</dd>
            </div>
          </dl>
        </div>

        <div class="rounded-2xl border border-white/10 bg-brand-card p-6">
          <button
            id="stripe-checkout"
            type="button"
            class="w-full rounded-full bg-brand-cyan py-3 font-display text-lg tracking-wide text-brand-black transition hover:bg-white disabled:cursor-not-allowed disabled:opacity-50"
          >
            Pay with card, Apple Pay, or Google Pay
          </button>
          <p class="mt-3 text-center text-xs text-brand-muted">
            Apple Pay and Google Pay appear automatically on supported devices at checkout.
          </p>
          <p id="checkout-error" class="mt-3 hidden text-center text-sm text-red-400"></p>
          <p id="checkout-fallback" class="mt-3 hidden text-center text-sm text-brand-gray">
            Stripe isn't configured yet.
            <a href="/contact" class="text-brand-cyan hover:underline">Contact us to order</a> instead.
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-brand-card p-6">
          <h3 class="font-display text-sm tracking-widest text-brand-cyan">AFTER PAYMENT</h3>
          <p class="mt-2 text-sm text-brand-gray">
            Email your design to <a href="mailto:hello@kustomfits.com" class="text-brand-cyan hover:underline">hello@kustomfits.com</a> with your order details. Include your preferred print placement and any special instructions. We'll send a proof before printing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />

  <script>
    import {
      cartItemCount,
      cartShipping,
      cartSubtotal,
      cartTotal,
      formatGBP,
      getCart,
    } from "../lib/cart";

    const items = getCart();
    const emptyEl = document.getElementById("checkout-empty");
    const contentEl = document.getElementById("checkout-content");
    const listEl = document.getElementById("checkout-items");
    const checkoutBtn = document.getElementById("stripe-checkout") as HTMLButtonElement;
    const errorEl = document.getElementById("checkout-error");
    const fallbackEl = document.getElementById("checkout-fallback");

    if (cartItemCount(items) === 0) {
      emptyEl?.classList.remove("hidden");
      contentEl?.classList.add("hidden");
    } else {
      const subtotal = cartSubtotal(items);
      const shipping = cartShipping(subtotal);

      if (listEl) {
        listEl.innerHTML = items
          .map(
            (item) => `
            <li class="flex justify-between gap-4">
              <span>${item.name} <span class="text-brand-muted">(${item.variant})</span> × ${item.quantity}</span>
              <span>${formatGBP(item.price * item.quantity)}</span>
            </li>
          `,
          )
          .join("");
      }

      document.getElementById("checkout-subtotal")!.textContent = formatGBP(subtotal);
      document.getElementById("checkout-shipping")!.textContent =
        shipping === 0 ? "Free" : formatGBP(shipping);
      document.getElementById("checkout-total")!.textContent = formatGBP(cartTotal(items));

      checkoutBtn?.addEventListener("click", async () => {
        checkoutBtn.disabled = true;
        checkoutBtn.textContent = "Redirecting…";
        errorEl?.classList.add("hidden");

        try {
          const res = await fetch("/api/create-checkout", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ items: getCart() }),
          });

          const data = (await res.json()) as { url?: string; error?: string };

          if (!res.ok) {
            if (res.status === 503) {
              fallbackEl?.classList.remove("hidden");
              checkoutBtn.classList.add("hidden");
              return;
            }
            throw new Error(data.error ?? "Checkout failed");
          }

          if (data.url) {
            window.location.href = data.url;
          }
        } catch (err) {
          errorEl!.textContent = err instanceof Error ? err.message : "Something went wrong";
          errorEl?.classList.remove("hidden");
          checkoutBtn.disabled = false;
          checkoutBtn.textContent = "Pay with card, Apple Pay, or Google Pay";
        }
      });
    }
  </script>
</Layout>
