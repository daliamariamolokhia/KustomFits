---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact" description="Contact Kustom Fits — questions about custom orders, designs, or bulk printing.">
  <Header slot="header" />

  <section class="px-4 py-12 sm:px-6">
    <div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-2">
      <div>
        <h1 class="font-display text-4xl tracking-wide text-white">Get in touch</h1>
        <p class="mt-3 text-brand-gray">
          Questions about a custom order, need help with your design, or want a bulk quote? We'd love to hear from you.
        </p>
        <dl class="mt-8 space-y-4 text-sm">
          <div>
            <dt class="font-display tracking-wide text-brand-cyan">Email</dt>
            <dd class="mt-1">
              <a href="mailto:hello@kustomfits.com" class="text-white hover:text-brand-cyan">
                hello@kustomfits.com
              </a>
            </dd>
          </div>
          <div>
            <dt class="font-display tracking-wide text-brand-cyan">Design files</dt>
            <dd class="mt-1 text-brand-gray">Send artwork to hello@kustomfits.com after placing your order</dd>
          </div>
          <div>
            <dt class="font-display tracking-wide text-brand-cyan">Response time</dt>
            <dd class="mt-1 text-brand-gray">Usually within 1–2 working days</dd>
          </div>
        </dl>
      </div>

      <form
        action="https://formsubmit.co/hello@kustomfits.com"
        method="POST"
        class="rounded-2xl border border-white/10 bg-brand-card p-6 sm:p-8"
      >
        <input type="hidden" name="_subject" value="New message from kustomfits.com" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />
        <input type="hidden" name="_next" value="https://kustomfits.com/contact?sent=1" />

        <div class="space-y-4">
          <div>
            <label for="name" class="block text-sm text-brand-gray">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-4 py-3 text-white outline-none focus:border-brand-cyan"
            />
          </div>
          <div>
            <label for="email" class="block text-sm text-brand-gray">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-4 py-3 text-white outline-none focus:border-brand-cyan"
            />
          </div>
          <div>
            <label for="message" class="block text-sm text-brand-gray">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-4 py-3 text-white outline-none focus:border-brand-cyan"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-full bg-brand-cyan py-3 font-display text-lg tracking-wide text-brand-black transition hover:bg-white"
          >
            Send message
          </button>
        </div>
      </form>
    </div>

    {
      Astro.url.searchParams.get("sent") === "1" && (
        <p class="mx-auto mt-8 max-w-5xl rounded-2xl border border-brand-cyan/30 bg-brand-cyan/10 px-4 py-3 text-center text-brand-gray">
          Thank you — your message has been sent. We'll be in touch soon.
        </p>
      )
    }
  </section>

  <Footer slot="footer" />
</Layout>
