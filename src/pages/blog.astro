---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Blog" description="The Kustom Fits blog — design tips, merch drops, and custom print inspiration.">
  <Header slot="header" />

  <section class="px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="font-display text-4xl tracking-wide text-white">Blog</h1>
      <p class="mt-3 text-brand-gray">
        Design tips, merch inspiration, and behind-the-scenes from the Kustom Fits studio.
      </p>

      <div class="mt-12 rounded-2xl border border-dashed border-white/15 bg-brand-card p-10 sm:p-14">
        <p class="font-display text-3xl tracking-wide text-brand-cyan">Coming soon</p>
        <p class="mt-4 text-brand-gray">
          We're working on our first posts — design guides, print tips, and customer spotlights.
        </p>
        <a href="/shop" class="mt-6 inline-block text-brand-cyan hover:text-white">Browse the shop while you wait →</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
