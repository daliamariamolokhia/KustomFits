---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProductCard from "../components/ProductCard.astro";
import Logo from "../components/Logo.astro";
import { products } from "../data/products";
---

<Layout title="Home">
  <Header slot="header" />

  <section class="relative overflow-hidden px-4 pb-16 pt-10 sm:px-6">
    <div class="pointer-events-none absolute -right-20 top-20 h-64 w-64 rounded-full bg-brand-blue/10 blur-3xl" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -left-20 bottom-10 h-48 w-48 rounded-full bg-brand-cyan/10 blur-3xl" aria-hidden="true"></div>

    <div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="font-display text-5xl leading-none tracking-wide text-white sm:text-7xl">
          KUSTOM
        </p>
        <p class="font-display -mt-1 text-5xl leading-none tracking-wide text-gradient-brand text-glow-cyan sm:text-7xl">
          FITS
        </p>
        <p class="mt-6 max-w-lg text-lg text-brand-gray">
          Custom made prints on t-shirts, tote bags, hoodies, caps, mugs and more. Your design, your fit.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/shop"
            class="rounded-full bg-brand-cyan px-8 py-3 font-display text-lg tracking-wide text-brand-black transition hover:bg-white"
          >
            Shop now
          </a>
          <a
            href="/about"
            class="rounded-full border border-white/20 px-8 py-3 font-display text-lg tracking-wide text-white transition hover:border-brand-cyan hover:text-brand-cyan"
          >
            How it works
          </a>
        </div>
      </div>

      <div class="relative flex justify-center">
        <div class="overflow-hidden rounded-2xl border border-white/10 bg-white p-4 shadow-2xl shadow-brand-cyan/10 sm:p-6">
          <Logo class="mx-auto h-auto max-h-[280px] w-full max-w-sm object-contain sm:max-h-[360px] sm:max-w-md" showBackground={false} />
        </div>
        <div
          class="absolute -bottom-4 -left-4 rounded-full border border-brand-cyan/30 bg-brand-black/90 px-4 py-2 text-xs uppercase tracking-widest text-brand-cyan"
          aria-hidden="true"
        >
          Print your way
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-brand-dark px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <ul class="grid gap-6 sm:grid-cols-3">
        <li class="rounded-2xl border border-white/10 p-5 text-center">
          <p class="font-display text-lg tracking-wide text-brand-cyan">Design studio</p>
          <p class="mt-2 text-sm text-brand-gray">Upload artwork, add text, or pick a template — like a mini Canva for your merch.</p>
        </li>
        <li class="rounded-2xl border border-white/10 p-5 text-center">
          <p class="font-display text-lg tracking-wide text-brand-cyan">Proof first</p>
          <p class="mt-2 text-sm text-brand-gray">Every order gets a digital mock-up before we print.</p>
        </li>
        <li class="rounded-2xl border border-white/10 p-5 text-center">
          <p class="font-display text-lg tracking-wide text-brand-cyan">Quality print</p>
          <p class="mt-2 text-sm text-brand-gray">Professional-grade printing built to last.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
        <div>
          <h2 class="font-display text-3xl tracking-wide text-white">Shop the range</h2>
          <p class="mt-2 text-brand-gray">T-shirts, hoodies, totes, caps, and mugs — all custom printed.</p>
        </div>
        <a href="/shop" class="text-sm font-semibold text-brand-cyan hover:text-white">View all →</a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="px-4 pb-20 sm:px-6">
    <div class="mx-auto max-w-4xl rounded-2xl border border-brand-cyan/20 bg-brand-card p-8 text-center sm:p-12">
      <h2 class="font-display text-2xl tracking-wide text-white sm:text-3xl">Ready to make it kustom?</h2>
      <p class="mt-4 text-brand-gray">
        Pick your product, choose your size and colour, then send us your design after checkout.
        We'll confirm everything before a single thread gets printed.
      </p>
      <a href="/shop" class="mt-6 inline-block font-display text-lg tracking-wide text-brand-cyan hover:text-white">Start your order →</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
