---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { products, getProduct, formatPrice } from "../../../data/products";
import { designTemplates, templateCategories } from "../../../data/design-templates";
import { designFonts } from "../../../data/design-fonts";
import { designShapes } from "../../../data/design-shapes";
import { brandColors } from "../../../data/brand-colors";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const product = getProduct(slug!);

if (!product) {
  return Astro.redirect("/shop");
}

const variant = Astro.url.searchParams.get("variant") ?? product.variants[0].label;

const studioProduct = JSON.stringify({
  id: product.id,
  name: product.name,
  slug: product.slug,
  price: product.price,
  variant,
});
---

<Layout title={`Design your ${product.name}`} description={`Create your custom print for ${product.name} — upload artwork, add text, or pick a template.`}>
  <Header slot="header" />

  <section class="px-4 py-8 sm:px-6 sm:py-12">
    <div class="mx-auto max-w-6xl">
      <a href={`/shop/${product.slug}`} class="text-sm text-brand-cyan hover:text-white">← Back to product</a>
      <div class="mt-4 flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-wider text-brand-cyan">Design studio</p>
          <h1 class="font-display text-3xl tracking-wide text-white sm:text-4xl">{product.name}</h1>
          <p class="mt-1 text-sm text-brand-gray">{variant} · {formatPrice(product.price)}</p>
        </div>
        <p class="text-xs text-brand-muted hidden sm:block">Drag to move · Handles to resize & rotate</p>
      </div>

      <div
        id="design-studio"
        data-product={studioProduct}
        class="mt-8 grid gap-8 lg:grid-cols-[1fr_340px]"
      >
        <div class="rounded-2xl border border-white/10 bg-brand-card p-4 sm:p-6">
          <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
            <div class="flex gap-2">
              <button id="undo-btn" type="button" disabled class="rounded-lg border border-white/15 px-3 py-1.5 text-sm text-brand-gray transition hover:border-brand-cyan hover:text-brand-cyan disabled:cursor-not-allowed disabled:opacity-40" title="Undo (Ctrl+Z)">↩ Undo</button>
              <button id="redo-btn" type="button" disabled class="rounded-lg border border-white/15 px-3 py-1.5 text-sm text-brand-gray transition hover:border-brand-cyan hover:text-brand-cyan disabled:cursor-not-allowed disabled:opacity-40" title="Redo (Ctrl+Y)">↪ Redo</button>
            </div>
            <p class="text-xs text-brand-muted sm:hidden">Tap & drag to move</p>
          </div>
          <canvas id="design-canvas" class="mx-auto w-full max-w-[520px] touch-none cursor-crosshair rounded-xl" aria-label="Product design preview"></canvas>
          <p class="mt-3 text-center text-xs text-brand-muted">Dashed area = print zone</p>
        </div>

        <div class="space-y-4">
          <div class="rounded-2xl border border-white/10 bg-brand-card p-5">
            <h2 class="font-display tracking-wide text-white">Layers</h2>
            <p id="layers-empty" class="mt-2 text-sm text-brand-muted">No elements yet — upload, add text, or pick a template.</p>
            <ul id="layers-list" class="mt-2 max-h-40 space-y-1 overflow-y-auto"></ul>
          </div>

          <div class="grid grid-cols-2 gap-1 rounded-xl border border-white/10 bg-brand-card p-1">
            <button type="button" data-design-tab="upload" class="rounded-lg border border-brand-cyan px-2 py-2.5 text-xs font-medium text-brand-cyan sm:text-sm">Upload</button>
            <button type="button" data-design-tab="text" class="rounded-lg border border-transparent px-2 py-2.5 text-xs font-medium text-brand-gray sm:text-sm">Text</button>
            <button type="button" data-design-tab="templates" class="rounded-lg border border-transparent px-2 py-2.5 text-xs font-medium text-brand-gray sm:text-sm">Templates</button>
            <button type="button" data-design-tab="shapes" class="rounded-lg border border-transparent px-2 py-2.5 text-xs font-medium text-brand-gray sm:text-sm">Shapes</button>
          </div>

          <div data-design-panel="upload" class="rounded-2xl border border-white/10 bg-brand-card p-5">
            <h2 class="font-display tracking-wide text-white">Upload artwork</h2>
            <p class="mt-1 text-sm text-brand-gray">PNG or JPG, max 3MB.</p>
            <label class="mt-4 flex cursor-pointer flex-col items-center rounded-xl border border-dashed border-white/20 bg-brand-black px-4 py-8 transition hover:border-brand-cyan">
              <span class="text-2xl">📁</span>
              <span class="mt-2 text-sm font-medium text-brand-cyan">Choose image</span>
              <input id="upload-image" type="file" accept="image/png,image/jpeg,image/webp" class="hidden" />
            </label>
          </div>

          <div data-design-panel="text" class="hidden rounded-2xl border border-white/10 bg-brand-card p-5">
            <h2 class="font-display tracking-wide text-white">Add text</h2>
            <div class="mt-4 space-y-3">
              <div>
                <label for="new-text" class="block text-xs text-brand-gray">Your text</label>
                <input id="new-text" type="text" placeholder="Your brand name" class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-4 py-2.5 text-white outline-none focus:border-brand-cyan" />
              </div>
              <div>
                <label for="new-font" class="block text-xs text-brand-gray">Font</label>
                <select id="new-font" class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-3 py-2.5 text-white outline-none focus:border-brand-cyan">
                  {designFonts.map((f) => <option value={f.value}>{f.label}</option>)}
                </select>
              </div>
              <div>
                <p class="text-xs text-brand-gray">Brand colours</p>
                <div class="mt-2 flex flex-wrap gap-2">
                  {brandColors.map((c) => (
                    <button type="button" data-pick-color={c.value} class="h-8 w-8 rounded-full border-2 border-white/20 transition hover:scale-110 hover:border-brand-cyan" style={`background-color: ${c.value}`} title={c.name} aria-label={c.name}></button>
                  ))}
                </div>
              </div>
              <div>
                <label for="new-color" class="block text-xs text-brand-gray">Custom colour</label>
                <input id="new-color" type="color" value="#00d4ff" class="mt-1 h-[42px] w-full cursor-pointer rounded-xl border border-white/15 bg-brand-black" />
              </div>
              <div>
                <label for="new-font-size" class="block text-xs text-brand-gray">Size</label>
                <input id="new-font-size" type="range" min="14" max="72" value="36" class="mt-1 w-full accent-brand-cyan" />
              </div>
              <button id="add-text-btn" type="button" class="w-full rounded-full bg-brand-cyan py-2.5 font-display tracking-wide text-brand-black hover:bg-white">Add to design</button>
            </div>
          </div>

          <div data-design-panel="templates" class="hidden rounded-2xl border border-white/10 bg-brand-card p-5">
            <h2 class="font-display tracking-wide text-white">Templates</h2>
            <p class="mt-1 text-sm text-brand-gray">Pick a style, then edit the text.</p>
            <div class="mt-4 max-h-64 space-y-4 overflow-y-auto">
              {templateCategories.map((category) => {
                const items = designTemplates.filter((t) => t.category === category);
                return (
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-brand-cyan">{category}</p>
                    <div class="mt-2 grid grid-cols-2 gap-2">
                      {items.map((t) => (
                        <button type="button" data-template={t.id} class="rounded-xl border border-white/10 bg-brand-black px-3 py-3 text-left transition hover:border-brand-cyan hover:bg-brand-dark">
                          <span class="text-lg">{t.emoji}</span>
                          <p class="mt-1 text-xs font-medium text-white">{t.name}</p>
                        </button>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          <div data-design-panel="shapes" class="hidden rounded-2xl border border-white/10 bg-brand-card p-5">
            <h2 class="font-display tracking-wide text-white">Add shape</h2>
            <p class="mt-1 text-sm text-brand-gray">Icons and shapes for your design.</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {brandColors.map((c) => (
                <button type="button" data-shape-color={c.value} class="shape-color-swatch h-7 w-7 rounded-full border-2 border-white/20 transition hover:scale-110 data-[active=true]:border-brand-cyan" style={`background-color: ${c.value}`} title={c.name} aria-label={c.name}></button>
              ))}
            </div>
            <input id="shape-color" type="hidden" value="#00d4ff" />
            <div class="mt-4 grid grid-cols-3 gap-2">
              {designShapes.map((s) => (
                <button type="button" data-add-shape={s.id} class="rounded-xl border border-white/10 bg-brand-black px-2 py-3 text-center transition hover:border-brand-cyan hover:bg-brand-dark">
                  <span class="text-xl">{s.emoji}</span>
                  <p class="mt-1 text-[10px] text-brand-gray">{s.name}</p>
                </button>
              ))}
            </div>
          </div>

          <div id="layer-controls" class="hidden rounded-2xl border border-brand-cyan/30 bg-brand-cyan/5 p-5">
            <h3 class="font-display text-sm tracking-widest text-brand-cyan">SELECTED ELEMENT</h3>
            <div class="mt-3 grid grid-cols-2 gap-3">
              <div>
                <label for="layer-scale" class="block text-xs text-brand-gray">Size</label>
                <input id="layer-scale" type="range" min="25" max="200" value="100" class="mt-1 w-full accent-brand-cyan" />
              </div>
              <div>
                <label for="layer-rotation" class="block text-xs text-brand-gray">Rotation</label>
                <input id="layer-rotation" type="range" min="-180" max="180" value="0" class="mt-1 w-full accent-brand-cyan" />
              </div>
            </div>
            <div id="color-presets-selected" class="mt-3 hidden">
              <p class="text-xs text-brand-gray">Colour</p>
              <div class="mt-2 flex flex-wrap gap-2">
                {brandColors.map((c) => (
                  <button type="button" data-apply-color={c.value} class="h-7 w-7 rounded-full border-2 border-white/20 transition hover:scale-110 hover:border-brand-cyan" style={`background-color: ${c.value}`} title={c.name} aria-label={c.name}></button>
                ))}
              </div>
              <input id="edit-shape-color" type="color" class="mt-2 h-9 w-full cursor-pointer rounded-lg border border-white/15 bg-brand-black" />
            </div>
            <div id="text-edit-group" class="mt-3 hidden space-y-3">
              <div>
                <label for="edit-text" class="block text-xs text-brand-gray">Text</label>
                <input id="edit-text" type="text" class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-3 py-2 text-white outline-none focus:border-brand-cyan" />
              </div>
              <div>
                <label for="edit-font" class="block text-xs text-brand-gray">Font</label>
                <select id="edit-font" class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-3 py-2 text-white outline-none focus:border-brand-cyan">
                  {designFonts.map((f) => <option value={f.value}>{f.label}</option>)}
                </select>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label for="edit-color" class="block text-xs text-brand-gray">Colour</label>
                  <input id="edit-color" type="color" class="mt-1 h-9 w-full cursor-pointer rounded-lg border border-white/15 bg-brand-black" />
                </div>
                <div>
                  <label for="edit-font-size" class="block text-xs text-brand-gray">Font size</label>
                  <input id="edit-font-size" type="number" min="10" max="96" class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-3 py-2 text-white outline-none focus:border-brand-cyan" />
                </div>
              </div>
            </div>
            <button id="layer-delete" type="button" class="mt-3 text-xs text-red-400 underline hover:text-red-300">Remove element</button>
          </div>

          <button id="add-to-cart-design" type="button" class="w-full rounded-full bg-brand-cyan py-3 font-display text-lg tracking-wide text-brand-black transition hover:bg-white">
            Add to cart — {formatPrice(product.price)}
          </button>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />

  <script>
    import "../../../scripts/design-studio.ts";
  </script>
</Layout>
