---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { products, getProduct, formatPrice } from "../../../data/products";
import { designTemplates } from "../../../data/design-templates";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const product = getProduct(slug!);

if (!product) {
  return Astro.redirect("/shop");
}

const variant = Astro.url.searchParams.get("variant") ?? product.variants[0].label;

const studioProduct = JSON.stringify({
  id: product.id,
  name: product.name,
  slug: product.slug,
  price: product.price,
  variant,
});
---

<Layout title={`Design your ${product.name}`} description={`Create your custom print for ${product.name} — upload artwork, add text, or pick a template.`}>
  <Header slot="header" />

  <section class="px-4 py-8 sm:px-6 sm:py-12">
    <div class="mx-auto max-w-6xl">
      <a href={`/shop/${product.slug}`} class="text-sm text-brand-cyan hover:text-white">← Back to product</a>
      <div class="mt-4 flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-wider text-brand-cyan">Design studio</p>
          <h1 class="font-display text-3xl tracking-wide text-white sm:text-4xl">{product.name}</h1>
          <p class="mt-1 text-sm text-brand-gray">{variant} · {formatPrice(product.price)}</p>
        </div>
        <p class="text-xs text-brand-muted">Drag elements to reposition · Click to select</p>
      </div>

      <div
        id="design-studio"
        data-product={studioProduct}
        class="mt-8 grid gap-8 lg:grid-cols-[1fr_340px]"
      >
        <!-- Canvas preview -->
        <div class="rounded-2xl border border-white/10 bg-brand-card p-4 sm:p-6">
          <canvas
            id="design-canvas"
            class="mx-auto w-full max-w-[520px] cursor-crosshair rounded-xl"
            aria-label="Product design preview"
          ></canvas>
          <p class="mt-3 text-center text-xs text-brand-muted">
            Dashed area = print zone
          </p>
        </div>

        <!-- Design tools -->
        <div class="space-y-4">
          <div class="flex gap-1 rounded-xl border border-white/10 bg-brand-card p-1">
            <button type="button" data-design-tab="upload" class="flex-1 rounded-lg border border-brand-cyan px-3 py-2 text-sm font-medium text-brand-cyan">
              Upload
            </button>
            <button type="button" data-design-tab="text" class="flex-1 rounded-lg border border-transparent px-3 py-2 text-sm font-medium text-brand-gray">
              Text
            </button>
            <button type="button" data-design-tab="templates" class="flex-1 rounded-lg border border-transparent px-3 py-2 text-sm font-medium text-brand-gray">
              Templates
            </button>
          </div>

          <!-- Upload panel -->
          <div data-design-panel="upload" class="rounded-2xl border border-white/10 bg-brand-card p-5">
            <h2 class="font-display tracking-wide text-white">Upload artwork</h2>
            <p class="mt-1 text-sm text-brand-gray">PNG or JPG, max 3MB. High-res files print best.</p>
            <label class="mt-4 flex cursor-pointer flex-col items-center rounded-xl border border-dashed border-white/20 bg-brand-black px-4 py-8 transition hover:border-brand-cyan">
              <span class="text-2xl">📁</span>
              <span class="mt-2 text-sm font-medium text-brand-cyan">Choose image</span>
              <input id="upload-image" type="file" accept="image/png,image/jpeg,image/webp" class="hidden" />
            </label>
          </div>

          <!-- Text panel -->
          <div data-design-panel="text" class="hidden rounded-2xl border border-white/10 bg-brand-card p-5">
            <h2 class="font-display tracking-wide text-white">Add text</h2>
            <div class="mt-4 space-y-3">
              <div>
                <label for="new-text" class="block text-xs text-brand-gray">Your text</label>
                <input id="new-text" type="text" placeholder="Your brand name" class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-4 py-2.5 text-white outline-none focus:border-brand-cyan" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label for="new-font" class="block text-xs text-brand-gray">Font</label>
                  <select id="new-font" class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-3 py-2.5 text-white outline-none focus:border-brand-cyan">
                    <option value="Bebas Neue">Bebas Neue</option>
                    <option value="Inter">Inter</option>
                  </select>
                </div>
                <div>
                  <label for="new-color" class="block text-xs text-brand-gray">Colour</label>
                  <input id="new-color" type="color" value="#00d4ff" class="mt-1 h-[42px] w-full cursor-pointer rounded-xl border border-white/15 bg-brand-black" />
                </div>
              </div>
              <div>
                <label for="new-font-size" class="block text-xs text-brand-gray">Size</label>
                <input id="new-font-size" type="range" min="14" max="72" value="36" class="mt-1 w-full accent-brand-cyan" />
              </div>
              <button id="add-text-btn" type="button" class="w-full rounded-full bg-brand-cyan py-2.5 font-display tracking-wide text-brand-black hover:bg-white">
                Add to design
              </button>
            </div>
          </div>

          <!-- Templates panel -->
          <div data-design-panel="templates" class="hidden rounded-2xl border border-white/10 bg-brand-card p-5">
            <h2 class="font-display tracking-wide text-white">Start from template</h2>
            <p class="mt-1 text-sm text-brand-gray">Pick a style, then edit the text to make it yours.</p>
            <div class="mt-4 grid grid-cols-2 gap-2">
              {designTemplates.map((t) => (
                <button
                  type="button"
                  data-template={t.id}
                  class="rounded-xl border border-white/10 bg-brand-black px-3 py-4 text-left transition hover:border-brand-cyan hover:bg-brand-dark"
                >
                  <span class="text-xl">{t.emoji}</span>
                  <p class="mt-1 text-sm font-medium text-white">{t.name}</p>
                </button>
              ))}
            </div>
          </div>

          <!-- Layer controls (shown when element selected) -->
          <div id="layer-controls" class="hidden rounded-2xl border border-brand-cyan/30 bg-brand-cyan/5 p-5">
            <h3 class="font-display text-sm tracking-widest text-brand-cyan">SELECTED ELEMENT</h3>
            <div class="mt-3">
              <label for="layer-scale" class="block text-xs text-brand-gray">Size</label>
              <input id="layer-scale" type="range" min="25" max="200" value="100" class="mt-1 w-full accent-brand-cyan" />
            </div>
            <div id="text-edit-group" class="mt-3 hidden space-y-3">
              <div>
                <label for="edit-text" class="block text-xs text-brand-gray">Text</label>
                <input id="edit-text" type="text" class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-3 py-2 text-white outline-none focus:border-brand-cyan" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label for="edit-color" class="block text-xs text-brand-gray">Colour</label>
                  <input id="edit-color" type="color" class="mt-1 h-9 w-full cursor-pointer rounded-lg border border-white/15 bg-brand-black" />
                </div>
                <div>
                  <label for="edit-font-size" class="block text-xs text-brand-gray">Size</label>
                  <input id="edit-font-size" type="number" min="10" max="96" class="mt-1 w-full rounded-xl border border-white/15 bg-brand-black px-3 py-2 text-white outline-none focus:border-brand-cyan" />
                </div>
              </div>
            </div>
            <button id="layer-delete" type="button" class="mt-3 text-xs text-red-400 underline hover:text-red-300">Remove element</button>
          </div>

          <button
            id="add-to-cart-design"
            type="button"
            class="w-full rounded-full bg-brand-cyan py-3 font-display text-lg tracking-wide text-brand-black transition hover:bg-white"
          >
            Add to cart — {formatPrice(product.price)}
          </button>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />

  <script>
    import "../../../scripts/design-studio.ts";
  </script>
</Layout>
