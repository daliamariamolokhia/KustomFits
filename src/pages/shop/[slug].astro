---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProductOptions from "../../components/ProductOptions.astro";
import ProductImage from "../../components/ProductImage.astro";
import { products, getProduct, formatPrice } from "../../data/products";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const product = getProduct(slug!);

if (!product) {
  return Astro.redirect("/shop");
}

const added = Astro.url.searchParams.get("added") === "1";
---

<Layout title={product.name} description={product.description}>
  <Header slot="header" />

  <section class="px-4 py-12 sm:px-6">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-2">
      <ProductImage product={product} large />

      <div>
        <a href="/shop" class="text-sm text-brand-cyan hover:text-white">← Back to shop</a>
        <p class="mt-4 text-xs uppercase tracking-wider text-brand-cyan">{product.category}</p>
        <h1 class="mt-2 font-display text-4xl tracking-wide text-white">{product.name}</h1>
        <p class="mt-2 font-display text-2xl tracking-wide text-brand-cyan">{formatPrice(product.price)}</p>
        <p class="mt-4 text-brand-gray">{product.description}</p>

        {
          added && (
            <p class="mt-4 rounded-xl border border-brand-cyan/30 bg-brand-cyan/10 px-4 py-3 text-sm text-brand-gray">
              Custom design added to cart!
              <a href="/checkout" class="ml-1 text-brand-cyan hover:underline">Go to checkout →</a>
            </p>
          )
        }

        <ol class="mt-6 space-y-2 text-sm text-brand-gray">
          <li><span class="text-brand-cyan">1.</span> Choose your size & colour</li>
          <li><span class="text-brand-cyan">2.</span> Design your print in our studio</li>
          <li><span class="text-brand-cyan">3.</span> Add to cart & checkout</li>
        </ol>

        <div class="mt-8 rounded-2xl border border-white/10 bg-brand-card p-6">
          <ProductOptions product={product} />
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
